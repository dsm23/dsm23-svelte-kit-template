{
  "name": "dsm23-svelte-kit-template",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint:js": "eslint \"**/*.{js,mjs,ts,tsx,svelte}\" --report-unused-disable-directives --max-warnings 0",
    "lint:css": "stylelint \"**/*.css\" --max-warnings 0 --allow-empty-input --cache --cache-strategy=content --cache-location=.stylelintcache",
    "lint": "run-p lint:js lint:css",
    "test:unit": "vitest --project=client --project=server",
    "test": "vitest",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@chromatic-com/storybook": "5.2.1",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@commitlint/types": "21.0.1",
    "@eslint/js": "10.0.1",
    "@fast-check/vitest": "0.4.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@playwright/test": "1.59.1",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-svelte-csf": "5.1.2",
    "@storybook/addon-vitest": "10.4.0",
    "@storybook/sveltekit": "10.4.0",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/kit": "2.60.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "@testing-library/user-event": "14.6.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "bits-ui": "2.18.1",
    "clsx": "2.1.1",
    "dotenv": "17.4.2",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-storybook": "10.4.0",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "knip": "6.13.1",
    "lefthook": "2.1.6",
    "lucide-svelte": "1.0.1",
    "mode-watcher": "1.1.0",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "prettier-plugin-css-order": "2.2.0",
    "prettier-plugin-svelte": "3.5.2",
    "prettier-plugin-tailwindcss": "0.8.0",
    "storybook": "10.4.0",
    "stylelint": "17.11.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "svelte": "5.55.7",
    "svelte-check": "4.4.8",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "1.0.7",
    "typed-query-selector": "2.12.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  },
  "packageManager": "pnpm@11.1.2"
}
